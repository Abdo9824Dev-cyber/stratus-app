# Copy this file to ".env" and adjust as needed.
# LOCAL values are below. When you move to the cloud later, you change ONLY these.

DB_USER=store
DB_PASSWORD=localpass
DB_HOST=db          # "db" is the service name in docker-compose; use "localhost" if running app outside Docker
DB_PORT=5432
DB_NAME=store

# App
APP_PORT=8080
